{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.modulora.dev/schemas/v0/taxonomy.schema.json",
  "title": "Modulora Taxonomy v0",
  "description": "The canonical, versioned category and component-type vocabulary. Discovery metadata only: taxonomy changes never alter a release's source content or digest.",
  "type": "object",
  "additionalProperties": false,
  "required": ["taxonomyVersion", "categories", "componentTypes", "aliases", "deprecated"],
  "properties": {
    "$schema": { "type": "string" },
    "taxonomyVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "description": { "type": "string" },
    "categories": { "$ref": "#/$defs/termList" },
    "componentTypes": { "$ref": "#/$defs/termList" },
    "aliases": {
      "type": "object",
      "description": "old-id → current-id migrations. Consumers MUST resolve aliases before validation.",
      "additionalProperties": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$" }
    },
    "deprecated": {
      "type": "array",
      "description": "IDs valid on existing releases but rejected for new publishes.",
      "items": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$" }
    }
  },
  "$defs": {
    "termList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 2, "maxLength": 40, "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$" },
          "label": { "type": "string", "minLength": 1, "maxLength": 60 },
          "description": { "type": "string", "maxLength": 280 }
        }
      }
    }
  }
}
