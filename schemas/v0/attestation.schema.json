{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.modulora.dev/schemas/v0/attestation.schema.json",
  "title": "Modulora Release Attestation v0",
  "description": "Immutable record binding an exact release digest, file digests, source commit, publisher authorization, and platform signature. Changing any covered field produces a new release.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "canonicalization",
    "itemRef",
    "releaseDigest",
    "files",
    "publisher",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "0" },
    "canonicalization": {
      "const": "modulora-json-c14n-0",
      "description": "Canonical serialization profile used to compute releaseDigest: UTF-8, lexicographically sorted keys, no insignificant whitespace, NFC-normalized strings."
    },
    "itemRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "name", "version"],
      "properties": {
        "namespace": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,38}[a-z0-9])?$" },
        "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$" },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]{1,32})?$"
        }
      }
    },
    "releaseDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Digest of the canonicalized companion manifest plus the sorted file digest list."
    },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300,
            "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//)[A-Za-z0-9._/@-]+$",
            "description": "Relative path. Absolute paths, traversal, and doubled separators are invalid."
          },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "authorizedAt"],
      "properties": {
        "identity": { "type": "string", "minLength": 1, "maxLength": 200 },
        "authorizedAt": { "type": "string", "format": "date-time" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "algorithm", "value", "signedAt"],
      "properties": {
        "keyId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "algorithm": { "type": "string", "enum": ["ed25519", "ecdsa-p256-sha256"] },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000,
          "pattern": "^[A-Za-z0-9+/=_-]+$",
          "description": "Base64 or base64url signature over releaseDigest."
        },
        "signedAt": { "type": "string", "format": "date-time" }
      }
    },
    "transparencyLog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "maxLength": 500, "pattern": "^https://\\S+$" },
        "entryId": { "type": "string", "maxLength": 200 }
      }
    }
  }
}
