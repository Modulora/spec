{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.modulora.dev/schemas/v0/evidence.schema.json",
  "title": "Modulora Trust Evidence v0",
  "description": "Scoped, timestamped evidence records for one exact release. There is deliberately no generic 'verified' or 'secure' value; every record names what was checked and its limitations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "itemRef",
    "releaseDigest",
    "records"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0"
    },
    "itemRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "name",
        "version"
      ],
      "properties": {
        "namespace": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,38}[a-z0-9])?$"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]{1,32})?$"
        }
      }
    },
    "releaseDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "status",
          "issuer",
          "timestamp"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "publisher-identity",
              "domain-verified",
              "content-integrity",
              "install-parity",
              "owner-verified",
              "source-linked",
              "artifact-signed",
              "secret-scan",
              "dependency-scan",
              "license-scan",
              "static-analysis",
              "build-checked",
              "human-reviewed",
              "source-not-assessed",
              "deprecated",
              "revoked"
            ],
            "description": "Scoped evidence kind. publisher-identity, domain-verified, content-integrity, and install-parity are the canonical registry-facing terms. owner-verified is retained for compatibility with early v0 records; new issuers SHOULD use publisher-identity."
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "warning",
              "asserted",
              "not-applicable"
            ]
          },
          "issuer": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "scope": {
            "type": "string",
            "maxLength": 500,
            "description": "Human-readable statement of exactly what was checked. Deprecated only when structured subject/coverage conveys the same information."
          },
          "toolVersion": {
            "type": "string",
            "maxLength": 100
          },
          "policyVersion": {
            "type": "string",
            "maxLength": 100
          },
          "limitations": {
            "type": "string",
            "maxLength": 1000,
            "description": "What this record does not prove. Required for scans, builds, human review, and source-not-assessed records.",
            "minLength": 1
          },
          "detailUrl": {
            "type": "string",
            "maxLength": 500,
            "pattern": "^https://\\S+$"
          },
          "supersededBy": {
            "type": "string",
            "maxLength": 200
          },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "value"
            ],
            "description": "The exact subject this evidence applies to; prevents a scoped result being presented as a generic badge.",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "release",
                  "publisher",
                  "domain",
                  "install-command",
                  "source"
                ]
              },
              "value": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              }
            }
          },
          "coverage": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "description": "Machine-readable bounds of the check. Fields not listed were not covered.",
            "properties": {
              "paths": {
                "type": "array",
                "maxItems": 500,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 300,
                  "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//)[A-Za-z0-9._/@-]+$"
                }
              },
              "command": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1000
              },
              "domain": {
                "type": "string",
                "minLength": 3,
                "maxLength": 253,
                "pattern": "^[a-z0-9.-]+$"
              },
              "commit": {
                "type": "string",
                "pattern": "^[a-f0-9]{40}$"
              }
            }
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Optional evidence expiry. Consumers MUST treat expired evidence as stale, not passed."
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "enum": [
                    "secret-scan",
                    "dependency-scan",
                    "license-scan",
                    "static-analysis",
                    "build-checked",
                    "human-reviewed",
                    "source-not-assessed"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "limitations"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "enum": [
                    "secret-scan",
                    "dependency-scan",
                    "license-scan",
                    "static-analysis",
                    "build-checked"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "toolVersion"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "domain-verified"
                }
              }
            },
            "then": {
              "required": [
                "subject"
              ],
              "properties": {
                "subject": {
                  "properties": {
                    "kind": {
                      "const": "domain"
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "install-parity"
                }
              }
            },
            "then": {
              "required": [
                "subject",
                "coverage"
              ],
              "properties": {
                "subject": {
                  "properties": {
                    "kind": {
                      "const": "install-command"
                    }
                  }
                },
                "coverage": {
                  "required": [
                    "command"
                  ]
                }
              }
            }
          }
        ]
      }
    }
  }
}